# ══════════════════════════════════════════════════════════════
# La Ligue des Ambitieuses — Configuration
# Copier ce fichier en .env et remplir les valeurs
# ══════════════════════════════════════════════════════════════

# Serveur
PORT=3000
NODE_ENV=development

# JWT — générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=changez_moi_en_production_avec_une_cle_aleatoire_de_64_caracteres
JWT_EXPIRES_IN=7d

# Base de données SQLite
DB_PATH=./data/ligue.db

# URL du site (pour les emails de reset de mot de passe)
SITE_URL=http://localhost:3000

# ── Email (NodeMailer / SMTP) ─────────────────────────────────
# Option 1 : Brevo (SendinBlue) SMTP
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=votre_email@exemple.fr
SMTP_PASS=votre_cle_api_brevo

# Option 2 : Gmail (décommenter)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=votre@gmail.com
# SMTP_PASS=votre_mot_de_passe_application

# Email expéditeur
EMAIL_FROM=noreply@liguedesambitieuses.fr
EMAIL_FROM_NAME=La Ligue des Ambitieuses

# ── MailJS (côté frontend, optionnel) ────────────────────────
# Ces clés sont utilisées côté client dans index.html
MAILJS_SERVICE_ID=votre_service_id
MAILJS_TEMPLATE_ID=votre_template_id
MAILJS_PUBLIC_KEY=votre_cle_publique

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_VOTRE_CLE_SECRETE
STRIPE_PUBLISHABLE_KEY=pk_test_VOTRE_CLE_PUBLIQUE
STRIPE_WEBHOOK_SECRET=whsec_VOTRE_SECRET_WEBHOOK

# Prix Stripe (créer les products dans le dashboard Stripe)
STRIPE_PRICE_INITIEE_MONTHLY=price_XXXX
STRIPE_PRICE_INITIEE_YEARLY=price_XXXX
STRIPE_PRICE_STRATEGE_MONTHLY=price_XXXX
STRIPE_PRICE_STRATEGE_YEARLY=price_XXXX
STRIPE_PRICE_VISIONNAIRE_MONTHLY=price_XXXX
STRIPE_PRICE_VISIONNAIRE_YEARLY=price_XXXX

# ── PayPal ───────────────────────────────────────────────────
PAYPAL_CLIENT_ID=votre_client_id_paypal
PAYPAL_CLIENT_SECRET=votre_client_secret_paypal
PAYPAL_MODE=sandbox
